# Root development env template. Copy to .env and fill real values locally.
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/philomind?schema=public"
# Cloud/Supabase: prefer the transaction pooler URL. Keep this per backend instance;
# if you run multiple replicas, lower it so replicas * limit stays below DB pool size.
PRISMA_CONNECTION_LIMIT=5
PRISMA_POOL_TIMEOUT=60
PRISMA_CONNECT_TIMEOUT=30
PRISMA_TRANSACTION_MAX_WAIT_MS=20000
PRISMA_TRANSACTION_TIMEOUT_MS=60000
DB_QUERY_CONCURRENCY=5
DB_QUEUE_TIMEOUT_MS=30000
PORT="3001"
BACKEND_PORT="3001"
FRONTEND_PORT="3000"
ADMIN_PORT="3002"
JWT_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
ENABLE_SWAGGER=true
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
OPENAI_API_KEY="your-llm-api-key"
OPENAI_API_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="meta-llama/llama-3-70b-instruct:free"
TTS_WORKER_URL="http://localhost:8000"
FRONTEND_REACT_APP_API_URL="http://localhost:3001/api"
ADMIN_REACT_APP_API_URL="http://localhost:3001/api"
